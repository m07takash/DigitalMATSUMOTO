# LLM API keys
OPENAI_API_KEY="API key"
GEMINI_API_KEY="API key"
ANTHROPIC_API_KEY="API key"
XAI_API_KEY="API key"
LLAMA_API_KEY="API key"

# HuggingFace token
HF_TOKEN="token"

# Notion connection info
NOTION_VERSION="2022-06-28"
NOTION_TOKEN="Notion token"

# Web search API
PERPLEXITY_API_KEY="API key"

# Time zone
TIMEZONE="Asia/Tokyo"

# Whether to move files in the temp folder (set to N to keep them, e.g. during tests)
TEMP_MOVE_FLG="Y"

# Enable login authentication ("N" skips login)
LOGIN_ENABLE_FLG="N"
# Login authentication method ("JSON" or "RDB")
#   "JSON": use the JSON file specified by USER_MST_FILE
#   "RDB":  use the digim_users table over the POSTGRES_* connection below
#           (the table is auto-created on first access)
LOGIN_AUTH_METHOD="JSON"

# Source for agent personas ("EXCEL" or "RDB" or "BOTH")
#   "EXCEL": use the xlsx files under user/common/agent/persona_data/
#   "RDB":   use the digim_agent_personas table in PostgreSQL
#   "BOTH":  merge Excel + RDB (RDB wins for the same persona_id)
AGENT_PERSONA_SOURCE="EXCEL"

# Master files
USER_MST_FILE="sample_users.json"
RAG_MST_FILE="sample_rags.json"
PROMPT_TEMPLATE_MST_FILE="sample_prompt_templates.json"
NOTION_MST_FILE="sample_notion_db.json"

# Embedding model
EMBEDDING_MODEL="text-embedding-3-large"
# Provider for embedding generation ("openai" or "azure"). When "azure", combine with AZURE_OPENAI_* and AZURE_OPENAI_EMBED_MODEL.
EMBED_PROVIDER="openai"
# Provider for speech-to-text ("openai" or "azure"). When "azure", combine with AZURE_OPENAI_WHISPER_MODEL (deployment name).
TRANSCRIBE_PROVIDER="openai"
# Whisper (Azure deployment name). Used when TRANSCRIBE_PROVIDER="azure".
AZURE_OPENAI_WHISPER_MODEL=<your Whisper deployment name>
# [Closed-network / Azure-only] Completely disable tiktoken and use a character-length-based approximation instead.
# tiktoken is only used to (a) clip embedding input to 8192 tokens and (b) display token counts, so on closed
# Azure Foundry / Azure OpenAI deployments setting this to "true" eliminates outbound traffic to
# openaipublic.blob.core.windows.net entirely (no cache file required).
TIKTOKEN_DISABLE="false"
# [Optional] Fallback for running with TIKTOKEN_DISABLE=false on a closed network.
# On a machine with outbound access, build the BPE cache, then copy it to this machine:
#   TIKTOKEN_CACHE_DIR=/path/to/cache python3 -c "import tiktoken; [tiktoken.get_encoding(n) for n in ('cl100k_base','o200k_base','p50k_base','r50k_base')]"
#TIKTOKEN_CACHE_DIR=/app/DigitalMATSUMOTO/.tiktoken_cache

# Storage for the 3-layer User Memory (history / nowaday / persona) — "EXCEL" or "NOTION" or "RDB"
#   EXCEL : user/common/user_memory/<layer>.xlsx
#   NOTION: The Notion DB specified by the "DigiM_UserMemory_History/Nowaday/Persona" keys in NOTION_MST_FILE
#   RDB   : digim_user_memory_<layer> table (PostgreSQL)
USER_MEMORY_HISTORY_BACKEND="EXCEL"
USER_MEMORY_NOWADAY_BACKEND="EXCEL"
USER_MEMORY_PERSONA_BACKEND="EXCEL"
# Layers enabled by the system default (comma-separated; may be empty)
USER_MEMORY_DEFAULT_LAYERS="persona,nowaday,history"
# Auto-generate History memory at session end
USER_MEMORY_HISTORY_AUTO_SAVE_FLG="N"
# Max characters of `history_records` passed to the LLM during Nowaday generation (oldest first are truncated when exceeded)
USER_MEMORY_NOWADAY_MAX_CHARS=50000
# Token cap when injecting the Persona profile
USER_MEMORY_PERSONA_TOKEN_LIMIT=3000
# During Persona merge, pending items with confidence >= this value are auto-promoted to approved
USER_MEMORY_AUTO_APPROVE_THRESHOLD=0.8
# Per Persona field (expertise / recurring_interests, etc.), total character cap for
# Approved + Pending labels. Approved is prioritized; the overflow is truncated.
USER_MEMORY_PERSONA_MAX_CHARS_PER_FIELD=300
# Total character cap when injecting History memory into the context
USER_MEMORY_HISTORY_MAX_CHARS=800
# Weight between tag match vs. time score when picking History memory (time side = this value, tag side = 1 - this value)
USER_MEMORY_HISTORY_RECENCY_WEIGHT=0.3
# Half-life (days) for the History memory time score
USER_MEMORY_HISTORY_RECENCY_HALF_LIFE_DAYS=30

# Streamlit settings
WEB_MAX_UPLOAD_SIZE=500
WEB_TITLE="Digital Twin"
WEB_DEFAULT_AGENT_FILE="agent_10Sample.json"
WEB_DEFAULT_SERVICE={"SERVICE_ID":"Streamlit", "SERVICE_DATA":{}}
WEB_DEFAULT_USER={"USER_ID":"WEB_DUMMY", "USER_DATA":{}}

# FastAPI settings
API_AGENT_FILE="agent_10Sample.json"
API_PORT=8899
API_DEFAULT_SESSION_NAME="API run"

# RDB connection info
POSTGRES_HOST=<host name>
POSTGRES_PORT=<port number>
POSTGRES_DB=digim_analytics
POSTGRES_USER=<user id>
POSTGRES_PASSWORD=<password>

# RDB (VectorDB) connection info / Azure OpenAI Service (also used for chat/image)
AZURE_OPENAI_ENDPOINT=<endpoint URL>
AZURE_OPENAI_API_KEY=<API key>
AZURE_OPENAI_EMBED_MODEL=<embedding deployment name>
# API version for chat/image engines (gpt-5 family requires the preview version)
# Per-engine override via ENGINE.LLM.*.PARAMETER.api_version in the agent JSON is also supported.
AZURE_OPENAI_API_VERSION="2024-12-01-preview"
