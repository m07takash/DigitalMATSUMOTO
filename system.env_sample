# LLMのAPIキー
OPENAI_API_KEY="APIキー"
GEMINI_API_KEY="APIキー"
ANTHROPIC_API_KEY="APIキー"
XAI_API_KEY="APIキー"
LLAMA_API_KEY="APIキー"

# HuggingFaceのトークン
HF_TOKEN="トークン"

# NOTION接続情報
NOTION_VERSION="2022-06-28"
NOTION_TOKEN="NOTIONのトークンキー"

# Web検索API
PERPLEXITY_API_KEY="APIキー"

# タイムゾーン
TIMEZONE="Asia/Tokyo"

# テンポラリファイルを動かす（テストで反復したいときはN）
TEMP_MOVE_FLG="Y"

# ログイン認証の有効化（"N"でログインスキップ）
LOGIN_ENABLE_FLG="N"
# ログイン認証方法（"JSON" or "RDB"）
#   "JSON": USER_MST_FILE で指定したJSONを使用
#   "RDB":  下のPOSTGRES_*接続情報で digim_users テーブルを使用（テーブルは初回アクセス時に自動作成）
LOGIN_AUTH_METHOD="JSON"

# エージェントペルソナのソース（"EXCEL" or "RDB" or "BOTH"）
#   "EXCEL": user/common/agent/persona_data/ 配下のxlsxを使用
#   "RDB":   PostgreSQL の digim_agent_personas テーブルを使用
#   "BOTH":  Excel + RDB をマージ（同persona_idはRDB優先）
AGENT_PERSONA_SOURCE="EXCEL"

# マスターファイル
USER_MST_FILE="sample_users.json"
RAG_MST_FILE="sample_rags.json"
PROMPT_TEMPLATE_MST_FILE="sample_prompt_templates.json"
NOTION_MST_FILE="sample_notion_db.json"

# 埋め込みベクトルモデル
EMBEDDING_MODEL="text-embedding-3-large"

# ユーザーメモリ（3層: short/mid/long）の保存先（"EXCEL" or "NOTION" or "RDB"）
#   EXCEL : user/common/user_memory/<layer>.xlsx
#   NOTION: NOTION_MST_FILE の "DigiM_UserMemory_Short/Mid/Long" キーで指定したDB
#   RDB   : digim_user_memory_<layer> テーブル（PostgreSQL）
USER_MEMORY_SHORT_BACKEND="EXCEL"
USER_MEMORY_MID_BACKEND="EXCEL"
USER_MEMORY_LONG_BACKEND="EXCEL"
# システムデフォルトで有効化する層（カンマ区切り。空でも可）
USER_MEMORY_DEFAULT_LAYERS="long,mid,short"
# 短期メモリのセッション終了時自動生成
USER_MEMORY_SHORT_AUTO_SAVE_FLG="N"
# 中期スケジュール: "off" | "monthly" | "weekly" | cron文字列(例: "0 3 1 * *")
USER_MEMORY_MID_SCHEDULE="off"
# 長期プロファイル注入時の上限トークン
USER_MEMORY_LONG_TOKEN_LIMIT=3000
# 長期マージ時、confidence がこの値以上の pending 項目を自動で approved に昇格
USER_MEMORY_AUTO_APPROVE_THRESHOLD=0.8
# 長期ペルソナ各フィールド (expertise / recurring_interests 等) で保持する
# Approved + Pending ラベルの合計文字数上限。Approved優先、超過分は切り捨て。
USER_MEMORY_LONG_MAX_CHARS_PER_FIELD=300
# 短期メモリのコンテキスト挿入時の合計文字数上限
USER_MEMORY_SHORT_MAX_CHARS=800
# 短期メモリ選定時、タグマッチ vs 時間スコアの重み(時間側=この値、タグ側=1-この値)
USER_MEMORY_SHORT_RECENCY_WEIGHT=0.3
# 短期メモリの時間スコアのハーフライフ(日数)
USER_MEMORY_SHORT_RECENCY_HALF_LIFE_DAYS=30

# Streamlit用の設定
WEB_MAX_UPLOAD_SIZE=500
WEB_TITLE="Digital Twin"
WEB_DEFAULT_AGENT_FILE="agent_X0Sample.json"
WEB_DEFAULT_SERVICE={"SERVICE_ID":"Streamlit", "SERVICE_DATA":{}}
WEB_DEFAULT_USER={"USER_ID":"WEB_DUMMY", "USER_DATA":{}}

# API用の設定
API_AGENT_FILE="agent_X0Sample.json"
API_PORT=8899
API_DEFAULT_SESSION_NAME="API実行"

# RDB接続情報
POSTGRES_HOST=ホスト名
POSTGRES_PORT=ポート番号
POSTGRES_DB=digim_analytics
POSTGRES_USER=ユーザーID
POSTGRES_PASSWORD=パスワード

# RDB(VectorDB)接続情報 / Azure OpenAI Service（chat/imageでも使用）
AZURE_OPENAI_ENDPOINT=エンドポイントURL
AZURE_OPENAI_API_KEY=APIキー
AZURE_OPENAI_EMBED_MODEL=Embeddingモデルのデプロイ名
# chat/image エンジン用のAPIバージョン（gpt-4o系: 2024-10-21、gpt-5系は新版が必要なことあり）
# エージェントJSONの ENGINE.LLM.*.PARAMETER.api_version でエンジン単位の上書きも可能
AZURE_OPENAI_API_VERSION="2024-10-21"